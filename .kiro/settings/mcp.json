{
  "mcpServers": {
    "kicad": {
      "command": "/Users/mac/mcp-servers/kicad-mcp/.venv/bin/kicad-mcp",
      "env": {
        "PATH": "/opt/homebrew/bin:/Users/mac/.local/bin:/usr/bin:/bin:/usr/sbin:/sbin",
        "KICAD_APP_PATH": "/Applications/KiCad/KiCad.app",
        "KICAD_SEARCH_PATHS": "/Users/mac/line_earphone/kicad,/Users/mac/ltspice,/Users/mac/Library/CloudStorage/GoogleDrive-convey12@qq.com/我的云端硬盘/script/project_data/generated_eda"
      },
      "disabled": false,
      "autoApprove": []
    },
    "spicebridge": {
      "command": "/Users/mac/.local/bin/uvx",
      "args": [
        "spicebridge"
      ],
      "env": {
        "PATH": "/opt/homebrew/bin:/Users/mac/.local/bin:/usr/bin:/bin:/usr/sbin:/sbin",
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": []
    }
  }
}
